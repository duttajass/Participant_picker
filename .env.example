# Server
PORT=3000

# Bot display name shown in the Teams meeting
BOT_NAME=PickerBot

# Set to "true" to run browser in background (recommended for production)
# Set to "false" to see the browser window (useful for debugging)
HEADLESS=false

# How long (ms) to wait for Teams UI elements to appear
JOIN_TIMEOUT_MS=30000

# How often (ms) the UI auto-refreshes the participant list (0 = disabled)
AUTO_REFRESH_MS=15000
PICK_COOLDOWN_MS=60000
